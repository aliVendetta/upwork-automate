# ── Server ────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=sqlite:///./upwork_dashboard.db

# ── Upwork OAuth2 (get from https://developers.upwork.com/) ──
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret
UPWORK_REDIRECT_URI=http://localhost:8000/api/auth/upwork/callback

# ── Frontend URL (used in OAuth redirects) ──
FRONTEND_URL=http://localhost:8000
